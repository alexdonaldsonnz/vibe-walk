# Directory Claude Code operates in (your project root)
VIBE_WALK_CWD=/Users/you/sources/myproject

# Claude permission mode: default | acceptEdits | bypassPermissions
# Use bypassPermissions while walking so nothing blocks waiting for approval
VIBE_WALK_PERMISSION=bypassPermissions

# Kokoro TTS endpoint (if using Docker)
KOKORO_URL=http://localhost:8880/v1/audio/speech
KOKORO_VOICE=af_sky

# Whisper model: tiny.en | base.en | small.en | medium.en
# base.en is a good balance of speed and accuracy on Apple Silicon
WHISPER_MODEL=base.en

# Server port
PORT=8000
